# Codoctor backend — optional AI layer.
# The app runs fully WITHOUT any of these (deterministic fallbacks). Set a key
# here to switch on the LLM Scribe, semantic retrieval, and Bangla narration.
#
# Copy this file to `.env` (same folder) and paste your real key:
#     cp .env.example .env
# `.env` is gitignored — never commit a real key.

# Your OpenAI API key (sk-...). Required to activate the AI features.
OPENAI_API_KEY=

# Optional model overrides (sensible, cheap defaults shown):
# CODOCTOR_LLM_MODEL=gpt-4o-mini
# CODOCTOR_EMBED_MODEL=text-embedding-3-small
